{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug API only (liviano)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-api",
      "program": "${workspaceFolder}/Api/bin/Debug/net10.0/Api.dll",
      "args": [],
      "cwd": "${workspaceFolder}/Api",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:44332"
      },
      "justMyCode": true,
      "suppressJITOptimizations": false,
      "enableStepFiltering": true
    },
    {
      "name": "Run Web (sin debugger WASM)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-web",
      "program": "${workspaceFolder}/Web/bin/Debug/net10.0/Web.dll",
      "args": [],
      "cwd": "${workspaceFolder}/Web",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:44331"
      },
      "justMyCode": true,
      "noDebug": true
    }
  ],
  "compounds": [
    {
      "name": "API + Web",
      "configurations": ["Debug API only (liviano)", "Run Web (sin debugger WASM)"],
      "stopAll": true
    }
  ]
}
